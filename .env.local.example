# ---- Firebase Web (client) config ----
# From Firebase Console > Project settings > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server only) ----
# Service account JSON, base64-encoded, OR use GOOGLE_APPLICATION_CREDENTIALS file path.
# Get JSON from: Console > Project settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_B64=

# ---- imgbb (server only) — image hosting instead of Firebase Storage ----
# Get a key at https://api.imgbb.com/
IMGBB_API_KEY=

# ---- Gemini (server only — never expose to client) ----
GEMINI_API_KEY=
# Models are overridable; defaults are known-good GA ids.
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
# Embedding dimensionality used for the Firestore vector index (keep in sync with firestore.indexes.json)
GEMINI_EMBED_DIM=768
